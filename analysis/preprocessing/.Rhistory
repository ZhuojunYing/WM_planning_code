aunt_mapping <- c("1" = 4, "2" = 4, "3" = 4, "4" = 1, "5" = 1, "6" = 1)
df_plan <- read_analysis_csv("data", "raw_data", "exp1_sim.csv") %>%
dplyr::mutate(condition = "planning")
