node == 1 ~ pmin(rank1, rank2), node == 4 ~ pmin(rank3, rank4), TRUE ~ NA_real_
)
) %>%
dplyr::select(subject, graph, node, condition, accuracy, p_rank) %>%
arrange(subject, graph, node, condition)
return(df_ranks)
}
# ------------------------------------------------------------------------------
# 6-Node Network Ranking (Experiment 1) - SIMULATION
# ------------------------------------------------------------------------------
create_ranked_path_df_pivot <- function(df) {
df_rewards_wide <- df %>%
filter(!is.na(graph), node %in% 1:6) %>%
mutate(
node_char = as.character(node),
actual_reward = as.numeric(actual_reward)
) %>%
dplyr::select(graph, condition, node_char, actual_reward) %>%
distinct() %>%
pivot_wider(
names_from = node_char, values_from = actual_reward,
names_prefix = "n", values_fn = list(actual_reward = max)
) %>%
rename(
n1_reward = !!sym("n1"), n2_reward = !!sym("n2"), n3_reward = !!sym("n3"),
n4_reward = !!sym("n4"), n5_reward = !!sym("n5"), n6_reward = !!sym("n6")
)
df_ranks <- df %>%
dplyr::select(graph, condition, node, accuracy) %>%
distinct() %>%
left_join(df_rewards_wide, by = c("graph", "condition")) %>%
filter(!is.na(n1_reward), !is.na(n2_reward), !is.na(n3_reward),
!is.na(n4_reward), !is.na(n5_reward), !is.na(n6_reward)) %>%
mutate(
path1_reward = n1_reward + n2_reward,
path2_reward = n1_reward + n3_reward,
path3_reward = n4_reward + n5_reward,
path4_reward = n4_reward + n6_reward
) %>%
group_by(graph, condition) %>%
rowwise() %>%
mutate(
path_rewards_vector = list(c(path1_reward, path2_reward, path3_reward, path4_reward)),
path_ranks_vector = list(rank(-path_rewards_vector, ties.method = "min")),
rank1 = unlist(path_ranks_vector)[1],
rank2 = unlist(path_ranks_vector)[2],
rank3 = unlist(path_ranks_vector)[3],
rank4 = unlist(path_ranks_vector)[4]
) %>%
ungroup() %>%
mutate(
p_rank = case_when(
node == 2 ~ rank1,
node == 3 ~ rank2,
node == 5 ~ rank3,
node == 6 ~ rank4,
node == 1 ~ pmin(rank1, rank2),
node == 4 ~ pmin(rank3, rank4),
TRUE ~ NA_real_
),
# INJECT DUMMY SUBJECT TO PREVENT DOWNSTREAM CRASHES
subject = "model_agent"
) %>%
dplyr::select(subject, graph, node, accuracy, condition, p_rank) %>%
arrange(graph, node, condition)
return(df_ranks)
}
# ------------------------------------------------------------------------------
# 40-Node Network Ranking (39 Paths)
# ------------------------------------------------------------------------------
create_ranked_path_df_39 <- function(df) {
df_ranks_calc <- df %>%
filter(!is.na(subject), !is.na(graph)) %>%
mutate(
path1_reward = n1_reward + n2_reward + n3_reward, path2_reward = n1_reward + n2_reward + n4_reward, path3_reward = n1_reward + n2_reward + n5_reward,
path4_reward = n1_reward + n6_reward + n7_reward, path5_reward = n1_reward + n6_reward + n8_reward, path6_reward = n1_reward + n6_reward + n9_reward,
path7_reward = n1_reward + n10_reward + n11_reward, path8_reward = n1_reward + n10_reward + n12_reward, path9_reward = n1_reward + n10_reward + n13_reward,
path10_reward = n14_reward + n15_reward + n16_reward, path11_reward = n14_reward + n15_reward + n17_reward, path12_reward = n14_reward + n15_reward + n18_reward,
path13_reward = n14_reward + n19_reward + n20_reward, path14_reward = n14_reward + n19_reward + n21_reward, path15_reward = n14_reward + n19_reward + n22_reward,
path16_reward = n14_reward + n23_reward + n24_reward, path17_reward = n14_reward + n23_reward + n25_reward, path18_reward = n14_reward + n23_reward + n26_reward,
path19_reward = n27_reward + n28_reward + n29_reward, path20_reward = n27_reward + n28_reward + n30_reward, path21_reward = n27_reward + n28_reward + n31_reward,
path22_reward = n27_reward + n32_reward + n33_reward, path23_reward = n27_reward + n32_reward + n34_reward, path24_reward = n27_reward + n32_reward + n35_reward,
path25_reward = n27_reward + n36_reward + n37_reward, path26_reward = n27_reward + n36_reward + n38_reward, path27_reward = n27_reward + n36_reward + n39_reward
) %>%
group_by(subject, graph, condition) %>%
rowwise() %>%
mutate(
path_rewards_vector = list(c(path1_reward, path2_reward, path3_reward, path4_reward, path5_reward, path6_reward, path7_reward, path8_reward, path9_reward,
path10_reward, path11_reward, path12_reward, path13_reward, path14_reward, path15_reward, path16_reward, path17_reward, path18_reward,
path19_reward, path20_reward, path21_reward, path22_reward, path23_reward, path24_reward, path25_reward, path26_reward, path27_reward)),
path_ranks_vector = list(rank(-path_rewards_vector, na.last = "keep", ties.method = "min"))
) %>%
ungroup()
node_path_map <- list(
"1" = 1:9, "2" = 1:3, "3" = 1, "4" = 2, "5" = 3, "6" = 4:6, "7" = 4, "8" = 5, "9" = 6, "10" = 7:9, "11" = 7, "12" = 8, "13" = 9,
"14" = 10:18, "15" = 10:12, "16" = 10, "17" = 11, "18" = 12, "19" = 13:15, "20" = 13, "21" = 14, "22" = 15, "23" = 16:18, "24" = 16, "25" = 17, "26" = 18,
"27" = 19:27, "28" = 19:21, "29" = 19, "30" = 20, "31" = 21, "32" = 22:24, "33" = 22, "34" = 23, "35" = 24, "36" = 25:27, "37" = 25, "38" = 26, "39" = 27
)
df_final_rank <- df_ranks_calc %>%
rowwise() %>%
mutate(
relevant_paths = list(node_path_map[[as.character(node)]]),
p_rank = min(unlist(path_ranks_vector)[relevant_paths], na.rm = TRUE)
) %>%
ungroup() %>%
dplyr::select(subject, graph, node, condition, accuracy, p_rank) %>%
arrange(subject, graph, node, condition)
return(df_final_rank)
}
# ==============================================================================
# PART 2: Statistical Modeling Functions
# ==============================================================================
is.binary <- function(x) { all(na.omit(x) %in% 0:1) }
zscore <- function(x) { as.numeric(scale(x, center = TRUE, scale = TRUE)) }
sprintf_transformer <- function(text, envir) {
m <- regexpr(":.+$", text)
if (m != -1) {
format <- substring(regmatches(text, m), 2)
regmatches(text, m) <- ""
res <- eval(parse(text = text, keep.source = FALSE), envir)
do.call(sprintf, list(glue("%{format}f"), res))
} else {
eval(parse(text = text, keep.source = FALSE), envir)
}
}
fmt <- function(..., .envir = parent.frame()) { glue(..., .transformer = sprintf_transformer, .envir = .envir) }
pval <- function(p) {
if (is.na(p)) return("NA")
if (p < .001) "p < .001" else glue("p = {str_sub(format(round(p, 3), nsmall=3), 2)}")
}
# ------------------------------------------------------------------------------
# Core Regression Wrapper
# ------------------------------------------------------------------------------
regress <- function(data, form, logistic = FALSE, mixed = TRUE, add_random = FALSE,
intercept = TRUE, standardize = FALSE, name = "", data_type = "participants",
reference_level = NULL, reference_levels = NULL) {
preds <- paste(get.vars(rhs(form)), collapse = " + ")
data <- as_tibble(data)
# Set reference level for column "condition"
if (!is.null(reference_level) && "condition" %in% names(data)) {
data$condition <- relevel(as.factor(data$condition), ref = reference_level)
}
if (!is.null(reference_levels)) {
if (is.vector(reference_levels) && !is.list(reference_levels)) reference_levels <- as.list(reference_levels)
for (col in names(reference_levels)) {
if (col %in% names(data)) {
ref_val <- reference_levels[[col]]
data[[col]] <- as.factor(data[[col]])
if (!ref_val %in% levels(data[[col]])) {
warning(sprintf("Reference level '%s' not found in column '%s'", ref_val, col))
} else {
data[[col]] <- stats::relevel(data[[col]], ref = ref_val)
}
}
}
}
if (standardize) {
for (k in get.vars(form)) {
if (k %in% names(data) && is.numeric(data[[k]]) && !is.binary(data[[k]])) {
data[[k]] <- zscore(data[[k]])
}
}
}
model <- if (mixed) {
form <- as.formula(glue("{form} + (1 | subject)"))
if (logistic) glmer(form, family = binomial, data = data) else lmer(form, data = data)
} else {
if (logistic) glm(form, family = binomial, data = data) else lm(form, data = data)
}
print(summary(model))
cat("regress data type:", data_type, "\n")
if (name != "") write_model_separate(model = model, name = name, data_type = data_type)
return(model)
}
# ------------------------------------------------------------------------------
# Export Model Summaries
# ------------------------------------------------------------------------------
write_model_separate <- function(model, name, data_type = "participants") {
coef_data <- broom.mixed::tidy(model, conf.int = TRUE)
if ("effect" %in% names(coef_data)) {
coef_data <- coef_data %>% filter(effect == "fixed", term != "(Intercept)")
} else {
coef_data <- coef_data %>% filter(term != "(Intercept)")
}
base_dir <- here("stats", paste0(name, "_uniform"))
dir.create(base_dir, recursive = TRUE, showWarnings = FALSE)
format_p <- function(p) {
if (is.na(p)) return("NA")
if (p < 0.001) return("< .001")
return(sub("^0", "", sprintf("%.3f", p)))
}
for (i in seq_len(nrow(coef_data))) {
row <- coef_data[i, ]
term_name <- row$term
beta_tex <- sprintf("%.3f", row$estimate)
p_tex <- format_p(row$p.value)
df_tex <- if ("df" %in% names(row) && !is.na(row$df)) sprintf("%d", round(row$df)) else "NA"
beta_file <- file.path(base_dir, paste0(term_name, "_beta.tex"))
p_file    <- file.path(base_dir, paste0(term_name, "_p.tex"))
df_file   <- file.path(base_dir, paste0(term_name, "_df.tex"))
writeLines(beta_tex, beta_file)
writeLines(p_tex, p_file)
writeLines(df_tex, df_file)
}
}
# ------------------------------------------------------------------------------
# Export Descriptive Stats
# ------------------------------------------------------------------------------
write_grouped_descriptive_stats <- function(data, variable, group_var = NULL, folder_name, data_type = "participants", format_digits = 3) {
data <- as_tibble(data)
if (!variable %in% names(data)) stop(paste("Variable", variable, "not found in data"))
if (!is.null(group_var) && !group_var %in% names(data)) stop(paste("Group variable", group_var, "not found in data"))
base_path <- here("stats", paste0(folder_name, "_uniform"))
dir.create(base_path, recursive = TRUE, showWarnings = FALSE)
if (is.null(group_var)) {
stats <- data %>%
summarise(mean_val = mean(.data[[variable]], na.rm = TRUE), sd_val = sd(.data[[variable]], na.rm = TRUE),
n_val = sum(!is.na(.data[[variable]])), median_val = median(.data[[variable]], na.rm = TRUE),
min_val = min(.data[[variable]], na.rm = TRUE), max_val = max(.data[[variable]], na.rm = TRUE), .groups = "drop")
format_str <- paste0("%.", format_digits, "f")
writeLines(sprintf(paste0("$M = ", format_str, "$"), stats$mean_val), file.path(base_path, paste0(variable, "_mean.tex")))
writeLines(sprintf(paste0("$SD = ", format_str, "$"), stats$sd_val), file.path(base_path, paste0(variable, "_sd.tex")))
} else {
stats <- data %>%
group_by(.data[[group_var]]) %>%
summarise(mean_val = mean(.data[[variable]], na.rm = TRUE), sd_val = sd(.data[[variable]], na.rm = TRUE),
n_val = sum(!is.na(.data[[variable]])), median_val = median(.data[[variable]], na.rm = TRUE),
min_val = min(.data[[variable]], na.rm = TRUE), max_val = max(.data[[variable]], na.rm = TRUE), .groups = "drop")
for (i in 1:nrow(stats)) {
group_name <- stats[[group_var]][i]
group_stats <- stats[i, ]
format_str <- paste0("%.", format_digits, "f")
writeLines(sprintf(paste0("$M = ", format_str, "$"), group_stats$mean_val), file.path(base_path, paste0(variable, "_", group_name, "_mean.tex")))
writeLines(sprintf(paste0("$SD = ", format_str, "$"), group_stats$sd_val), file.path(base_path, paste0(variable, "_", group_name, "_sd.tex")))
}
}
invisible(stats)
}
# ------------------------------------------------------------------------------
# Compare Adjacent Path Ranks (ANOVA)
# ------------------------------------------------------------------------------
# ------------------------------------------------------------------------------
# Compare Adjacent Path Ranks (ANOVA)
# ------------------------------------------------------------------------------
compare_adjacent_path_ranks <- function(data, y_var = "accuracy", folder_name, mixed = TRUE, data_type = "participants") {
base_dir <- here("stats", folder_name, "")
dir.create(base_dir, recursive = TRUE, showWarnings = FALSE)
# NEW: Format exact p-values to 3 decimal places (APA style)
format_p <- function(p) {
if (is.na(p)) return("NA")
if (p < 0.001) return("< .001")
return(sub("^0", "", sprintf("%.3f", p)))
}
if (!"path_rank" %in% names(data)) stop("Column 'path_rank' not found in data.")
if (!y_var %in% names(data)) stop(sprintf("Column '%s' not found in data.", y_var))
ranks <- sort(unique(data$path_rank))
cat(sprintf("\n=== ANOVA ADJACENT RANKS: %s (%s) ===\n", folder_name, y_var))
for (i in 1:(length(ranks) - 1)) {
rank_A <- ranks[i]
rank_B <- ranks[i+1]
sub_data <- data %>% filter(path_rank %in% c(rank_A, rank_B))
if (nrow(sub_data) < 5) next
form_str <- paste0(y_var, " ~ as.factor(path_rank)")
if (mixed) {
model <- tryCatch({ lmer(as.formula(paste0(form_str, " + (1|subject)")), data = sub_data, REML = FALSE) }, error = function(e) NULL)
} else {
model <- tryCatch({ lm(as.formula(form_str), data = sub_data) }, error = function(e) NULL)
}
if (is.null(model)) { cat(sprintf("Model failed to converge for rank %d vs %d\n", rank_A, rank_B)); next }
anova_res <- anova(model)
if (mixed) {
F_val <- anova_res$"F value"[1]; p_val <- anova_res$"Pr(>F)"[1]
numDF <- anova_res$"NumDF"[1]; denDF <- anova_res$"DenDF"[1]
} else {
F_val <- anova_res$"F value"[1]; p_val <- anova_res$"Pr(>F)"[1]
numDF <- anova_res$"Df"[1]; denDF <- anova_res$"Df"[2]
}
prefix <- paste0(y_var, "_rank_", rank_A, "_vs_", rank_B)
# Format the isolated p-value and the full string
p_exact_tex <- format_p(p_val)
p_str <- if(is.na(p_val)) "ns" else if(p_val < .001) "p < .001" else sprintf("p = %s", p_exact_tex)
full_stat_tex <- sprintf("$F(%.0f, %.0f) = %.3f$, %s", numDF, denDF, F_val, p_str)
# Write files
writeLines(sprintf("%.3f", F_val), file.path(base_dir, paste0(prefix, "_F.tex")))
writeLines(p_exact_tex, file.path(base_dir, paste0(prefix, "_p.tex"))) # Changed from _p_stars.tex
writeLines(full_stat_tex, file.path(base_dir, paste0(prefix, "_full_stat.tex")))
cat(sprintf("  %d vs %d -> %s\n", rank_A, rank_B, full_stat_tex))
}
}
# ==============================================================================
# PART 3: Execution Block
# ==============================================================================
# Load Data
df_exp1_beh <- read_csv(here("processed_data", "exp1_beh.csv"), show_col_types = FALSE)
df_exp2_beh <- read_csv(here("processed_data", "exp2_beh.csv"), show_col_types = FALSE)
df_exp1_sim <- read_csv(here("processed_data", "exp1_sim.csv"), show_col_types = FALSE)
df_exp2_sim <- read_csv(here("processed_data", "exp2_sim.csv"), show_col_types = FALSE)
df_exp2_40n_beh <- read_csv(here("processed_data", "exp2_40n_beh.csv"), show_col_types = FALSE)
df_n30_beh <- read_csv(here("processed_data", "exp3_beh.csv"), show_col_types = FALSE)
df_n30_model <- read_csv(here("processed_data", "exp3_sim.csv"), show_col_types = FALSE)
df_exp1_sim_preregistered <- read_csv(here("processed_data", "exp1_sim_preregistered.csv"), show_col_types = FALSE)
# 1. Write Descriptive Stats
write_grouped_descriptive_stats(df_exp1_sim, "accuracy", "condition", "exp1_sim")
write_grouped_descriptive_stats(df_exp1_beh, "accuracy", "condition", "exp1_beh")
write_grouped_descriptive_stats(df_exp2_sim, "accuracy", "condition", "exp2_sim")
write_grouped_descriptive_stats(df_exp2_beh, "accuracy", "condition", "exp2_beh")
write_grouped_descriptive_stats(df_exp2_40n_beh, "accuracy", "condition", "exp2_40n_beh")
write_grouped_descriptive_stats(df_exp1_sim %>% filter(condition == "planning"), "norm_reward", folder_name = "exp1_sim")
write_grouped_descriptive_stats(df_exp1_beh %>% filter(condition == "planning"), "norm_reward",  folder_name = "exp1_beh")
write_grouped_descriptive_stats(df_exp2_sim %>% filter(condition == "planning"), "norm_reward", folder_name =  "exp2_sim")
write_grouped_descriptive_stats(df_exp2_beh %>% filter(condition == "planning"), "norm_reward",  folder_name ="exp2_beh")
write_grouped_descriptive_stats(df_exp2_40n_beh %>% filter(condition == "planning"), "norm_reward",  folder_name ="exp2_40n_beh")
# Prep relational reward columns for regression (set non-leaves to 0)
prep_for_regression <- function(df) {
df %>% mutate(node_reward = actual_reward, parent_reward = ifelse(!is_leaf, 0, parent_reward), aunt_reward = ifelse(!is_leaf, 0, aunt_reward))
}
prep_for_regression_40n <- function(df) {
df %>% mutate(node_reward = actual_reward, preceding_sum_reward = ifelse(!is_leaf, 0, preceding_sum_reward), aunt_reward = ifelse(!is_leaf, 0, aunt_reward))
}
df_exp1_sim <- prep_for_regression(df_exp1_sim)
df_exp1_beh <- prep_for_regression(df_exp1_beh)
df_exp2_sim <- prep_for_regression(df_exp2_sim)
df_exp2_beh <- prep_for_regression(df_exp2_beh)
df_exp2_40n_beh <- prep_for_regression_40n(df_exp2_40n_beh)
# 2. Run Main Regressions
reg_formula <- accuracy ~ (scale(node_reward) + scale(node_reward^2) + scale(sibling_reward) + scale(sibling_reward^2) + scale(aunt_reward) + scale(parent_reward)) * condition
df_exp1_sim %>% regress(reg_formula, reference_level = "exposure", add_random = FALSE, mixed = FALSE) %>% write_model_separate("exp1_sim")
df_exp1_beh %>% regress(reg_formula, reference_level = "exposure") %>% write_model_separate("exp1_beh")
df_exp2_sim %>% regress(reg_formula, reference_level = "exposure", add_random = FALSE, mixed = FALSE) %>% write_model_separate("exp2_sim")
df_exp2_beh %>% regress(reg_formula, reference_level = "exposure") %>% write_model_separate("exp2_beh")
reg_formula_40n <- accuracy ~ (scale(node_reward) + scale(node_reward^2) + scale(sibling_reward) + scale(sibling_reward^2) + scale(aunt_reward) + scale(preceding_sum_reward)) * condition
df_exp2_40n_beh %>% regress(reg_formula_40n, reference_level = "exposure") %>% write_model_separate("exp2_40n_beh")
# Exp3 Regressions
df_n30_beh %>% regress(norm_reward ~ order * tree, reference_levels = c("order" = "breadth", "tree" = "wide")) %>% write_model_separate("n30_beh_action")
df_n30_model %>% regress(norm_reward ~ order * tree, reference_levels = c("order" = "breadth", "tree" = "wide"), add_random = FALSE, mixed = FALSE) %>% write_model_separate("n30_model_action")
df_n30_beh %>% regress(accuracy ~ order * tree, reference_levels = c("order" = "breadth", "tree" = "wide")) %>% write_model_separate("n30_beh_recall")
df_n30_model %>% regress(accuracy ~ order * tree, reference_levels = c("order" = "breadth", "tree" = "wide"), add_random = FALSE, mixed = FALSE) %>% write_model_separate("n30_model_recall")
# 3. Path Rank Calculations & Comparisons
df_exp1_beh_rank <- create_ranked_path_df(df_exp1_beh) %>% mutate(path_rank = p_rank)
df_exp1_sim_rank <- create_ranked_path_df_pivot(df_exp1_sim) %>% mutate(path_rank = p_rank)
df_exp2_beh_rank <- create_ranked_path_df_12(df_exp2_beh) %>% mutate(path_rank = p_rank)
df_exp2_sim_rank <- create_ranked_path_df_pivot_12(df_exp2_sim) %>% mutate(path_rank = p_rank)
# Grouped Path Rank summaries (Removed 'path' variable to prevent errors)
df_exp1_beh_rank_grouped <- df_exp1_beh_rank %>% group_by(subject, condition, graph, path_rank) %>% summarise(accuracy = mean(accuracy, na.rm=TRUE), .groups = "drop")
df_exp1_sim_rank_grouped <- df_exp1_sim_rank %>% group_by(subject, condition, graph, path_rank) %>% summarise(accuracy = mean(accuracy, na.rm=TRUE), .groups = "drop")
df_exp2_beh_rank_grouped <- df_exp2_beh_rank %>% group_by(subject, condition, graph, path_rank) %>% summarise(accuracy = mean(accuracy, na.rm=TRUE), .groups = "drop")
df_exp2_sim_rank_grouped <- df_exp2_sim_rank %>% group_by(subject, condition, graph, path_rank) %>% summarise(accuracy = mean(accuracy, na.rm=TRUE), .groups = "drop")
# Compare Adjacent Ranks
compare_adjacent_path_ranks(df_exp1_beh_rank_grouped %>% filter(condition == "planning"), y_var = "accuracy", folder_name = "exp1_beh_planning", mixed = TRUE, data_type = "participants")
compare_adjacent_path_ranks(df_exp1_sim_rank_grouped %>% filter(condition == "planning"), y_var = "accuracy", folder_name = "exp1_sim_planning", mixed = FALSE, data_type = "model")
compare_adjacent_path_ranks(df_exp1_beh_rank_grouped %>% filter(condition == "exposure"), y_var = "accuracy", folder_name = "exp1_beh_exposure", mixed = TRUE, data_type = "participants")
compare_adjacent_path_ranks(df_exp1_sim_rank_grouped %>% filter(condition == "exposure"), y_var = "accuracy", folder_name = "exp1_sim_exposure", mixed = FALSE, data_type = "model")
compare_adjacent_path_ranks(df_exp2_beh_rank_grouped %>% filter(condition == "planning"), y_var = "accuracy", folder_name = "exp2_beh_planning", mixed = TRUE, data_type = "participants")
compare_adjacent_path_ranks(df_exp2_sim_rank_grouped %>% filter(condition == "planning"), y_var = "accuracy", folder_name = "exp2_sim_planning", mixed = FALSE, data_type = "model")
compare_adjacent_path_ranks(df_exp2_beh_rank_grouped %>% filter(condition == "exposure"), y_var = "accuracy", folder_name = "exp2_beh_exposure", mixed = TRUE, data_type = "participants")
compare_adjacent_path_ranks(df_exp2_sim_rank_grouped %>% filter(condition == "exposure"), y_var = "accuracy", folder_name = "exp2_sim_exposure", mixed = FALSE, data_type = "model")
# Exp1 S2 Sim Specific Analysis
write_grouped_descriptive_stats(df_exp1_sim_preregistered, "accuracy", "condition", "exp1_sim_preregistered")
write_grouped_descriptive_stats(df_exp1_sim_preregistered %>% filter(condition == "planning"), "norm_reward", folder_name = "exp1_sim_preregistered")
df_exp1_sim_preregistered <- prep_for_regression(df_exp1_sim_preregistered)
df_exp1_sim_rank_fit <- create_ranked_path_df_pivot(df_exp1_sim_preregistered) %>% mutate(path_rank = p_rank)
df_exp1_sim_rank_grouped_fit <- df_exp1_sim_rank_fit %>% group_by(subject, condition, graph, path_rank) %>% summarise(accuracy = mean(accuracy, na.rm=TRUE), .groups = "drop")
df_exp1_sim_rank_grouped_fit %>% regress(accuracy ~ path_rank * condition, reference_level = "exposure", add_random = FALSE, mixed = FALSE) %>% write_model_separate("exp1_sim_preregistered")
compare_adjacent_path_ranks(df_exp1_sim_rank_grouped_fit %>% filter(condition == "planning"), y_var = "accuracy", folder_name = "exp1_sim_preregistered_planning", mixed = FALSE, data_type = "model")
# ==============================================================================
# Script: Simulation Data Preprocessing (Experiment 2)
# Description: Merges planning and exposure simulation data, handles booleans,
#              and calculates relational node rewards (mother, siblings, aunts).
# ==============================================================================
library(dplyr)
library(readr)
library(here)
# -----------------------------------------------------------------------------
# Step 1: Define Relational Mappings (Vectorized)
# -----------------------------------------------------------------------------
# Splitting the 1-to-many relationships (siblings and aunts) into two
# 1-to-1 mappings allows us to use fast, vectorized lookups instead of loops.
mother_map <- c("2"=1, "3"=1, "4"=1, "6"=5, "7"=5, "8"=5, "10"=9, "11"=9, "12"=9)
# Mapping for the first sibling
sib1_map <- c("1"=5, "2"=3, "3"=2, "4"=2, "5"=1, "6"=7, "7"=6, "8"=6, "9"=1, "10"=11, "11"=10, "12"=10)
# Mapping for the second sibling
sib2_map <- c("1"=9, "2"=4, "3"=4, "4"=3, "5"=9, "6"=8, "7"=8, "8"=7, "9"=5, "10"=12, "11"=12, "12"=11)
# Mapping for the first and second aunt (only applies to leaves)
aunt1_map <- c("2"=5, "3"=5, "4"=5, "6"=1, "7"=1, "8"=1, "10"=1, "11"=1, "12"=1)
aunt2_map <- c("2"=9, "3"=9, "4"=9, "6"=9, "7"=9, "8"=9, "10"=5, "11"=5, "12"=5)
# -----------------------------------------------------------------------------
# Step 2: Load and Combine Datasets
# -----------------------------------------------------------------------------
# Load data and tag with conditions
df_plan <- read_csv(here("raw_data", "12n_sim_0430.csv"), show_col_types = FALSE) %>%
mutate(condition = "planning")
df_exp <- read_csv(here("raw_data", "exp2_sim_exp.csv"), show_col_types = FALSE) %>%
mutate(condition = "exposure")
# Combine for uniform processing
df_raw <- bind_rows(df_plan, df_exp)
# -----------------------------------------------------------------------------
# Step 3: Base Metrics and Data Cleaning
# -----------------------------------------------------------------------------
df_base <- df_raw %>%
# Safely handle string Booleans
mutate(across(
where(is.character),
~ ifelse(.x == "True", TRUE, ifelse(.x == "False", FALSE, .x))
)) %>%
# Remove duplicate nodes per graph
distinct(condition, graph, node, .keep_all = TRUE) %>%
# Calculate base metrics
mutate(
norm_reward = (V - min_path_reward) / (max_path_reward - min_path_reward + 1e-06),
is_leaf = node %in% c(2, 3, 4, 6, 7, 8, 10, 11, 12),
error = abs(actual_reward - estimated_reward),
accuracy = ifelse(estimated_reward == actual_reward, 1, 0),
parent_reward = ifelse(node %in% c(2, 3, 4, 6, 7, 8, 10, 11, 12),path_reward - actual_reward,0),
correct_choice = ifelse(V == max_path_reward, 1, 0),
# Assign relational nodes based on dictionaries
mother_node = as.numeric(mother_map[as.character(node)]),
sib1_node   = as.numeric(sib1_map[as.character(node)]),
sib2_node   = as.numeric(sib2_map[as.character(node)]),
aunt1_node  = as.numeric(aunt1_map[as.character(node)]),
aunt2_node  = as.numeric(aunt2_map[as.character(node)])
)
# -----------------------------------------------------------------------------
# Step 4: Calculate Relational Rewards
# -----------------------------------------------------------------------------
df_clean <- df_base %>%
# Group by condition and graph to ensure we match within the same network
group_by(condition, graph) %>%
mutate(
# Fast vectorized matching for node rewards
mother_reward_raw = actual_reward[match(mother_node, node)],
sib1_reward       = actual_reward[match(sib1_node, node)],
sib2_reward       = actual_reward[match(sib2_node, node)],
aunt1_reward      = actual_reward[match(aunt1_node, node)],
aunt2_reward      = actual_reward[match(aunt2_node, node)]
) %>%
ungroup() %>%
mutate(
# Conditionally keep mother reward only for leaves
mother_reward = ifelse(is_leaf, mother_reward_raw, NA_real_),
# Calculate means for 1-to-many relationships (ignoring NAs)
sibling_reward = rowMeans(cbind(sib1_reward, sib2_reward), na.rm = TRUE),
aunt_reward_raw = rowMeans(cbind(aunt1_reward, aunt2_reward), na.rm = TRUE),
# Ensure aunts are only assigned to leaves, and fix NaN from rowMeans
aunt_reward = ifelse(is_leaf, aunt_reward_raw, NA_real_),
sibling_reward = ifelse(is.nan(sibling_reward), NA_real_, sibling_reward),
aunt_reward = ifelse(is.nan(aunt_reward), NA_real_, aunt_reward)
) %>%
# Select and order final columns
dplyr::select(
is_leaf, graph, condition, node, norm_reward, actual_reward,
estimated_reward, parent_reward, mother_reward, sibling_reward,
aunt_reward, accuracy, correct_choice
)
# -----------------------------------------------------------------------------
# Step 5: Export Processed Data
# -----------------------------------------------------------------------------
write_csv(df_clean, here("processed_data", "exp2_sim.csv"))
library(lme4)
df <- read.csv( here("processed_data", "exp2_sim.csv"))
df <- df  %>% mutate(parent_reward = ifelse(is_leaf == FALSE, 0, parent_reward),
aunt_reward = ifelse(is_leaf == FALSE, 0, aunt_reward))
model <- lm (accuracy~  (scale(actual_reward)+ scale( sibling_reward)+scale( parent_reward) +scale( aunt_reward) ) *condition  , df)
summary(model)
